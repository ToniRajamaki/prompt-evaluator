# Copy this file to .env and fill in your key.
# OpenAI API key (required for chat + embeddings)
OPENAI_API_KEY=sk-your-key-here

# Chat model (optional, defaults to openai:gpt-4o-mini)
OPENAI_MODEL=openai:gpt-4o-mini

# Embedding model used to vectorize chunks (optional).
# Must match the vector dimension in the DB schema (1536 for these models).
EMBEDDING_MODEL=text-embedding-3-small

# Postgres connection (matches docker-compose.yml).
DATABASE_URL=postgresql://sourcechat:sourcechat@localhost:5432/sourcechat

# Where uploaded files are stored on disk (relative to the backend folder).
STORAGE_DIR=storage

# On first startup, seed the demo documents from ../files into the DB.
SEED_DEMO_FILES=true

# Optional: override the assistant system prompt
# SYSTEM_PROMPT=You are a helpful assistant.
